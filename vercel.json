{
  "version": 2,
  "installCommand": "npm install --production",
  "routes": [
    {
      "src": "/api/auth",
      "dest": "/api/auth.js"
    },
    {
      "src": "/api/callback",
      "dest": "/api/callback.js"
    },
    {
      "handle": "filesystem"
    }
  ],
  "headers": [
    {
      "source": "/admin/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    }
  ]
}
