{
  "installCommand": "npm install --production",
  "buildCommand": "mkdir -p public && find . -maxdepth 1 ! -name public ! -name node_modules ! -name .git ! -name .vercel ! -name . -exec cp -r {} public/ \\;",
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/api/auth/callback",
      "destination": "/api/callback.js"
    },
    {
      "source": "/api/auth",
      "destination": "/api/auth.js"
    },
    {
      "source": "/api/callback",
      "destination": "/api/callback.js"
    }
  ],
  "headers": [
    {
      "source": "/admin/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    }
  ]
}
